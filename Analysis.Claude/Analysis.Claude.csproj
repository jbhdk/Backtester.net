<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <RootNamespace>Backtester.Analysis.Claude</RootNamespace>
    <AssemblyName>Backtester.Analysis.Claude</AssemblyName>

    <PackageId>backtester.net.analysis.claude</PackageId>
    <Authors>Jesper Baagøe Hansen</Authors>
    <Description>Claude Analysis client for the backtester.net engine: carries an Analysis request to Anthropic's Claude and returns its raw answer. Interprets nothing.</Description>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <!-- File that persists the auto-incremented build number between builds. -->
    <BuildNumberFile>$(MSBuildProjectDirectory)\buildnumber.txt</BuildNumberFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <PropertyGroup>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Analysis\Analysis.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Anthropic" Version="12.36.0" />
  </ItemGroup>

  <!--
    Increments and persists the build number. Hooked to BeforeBuild, which only
    runs in the primary build pass (not in the separate NuGet pack/nuspec passes),
    so the counter advances exactly once per build.
  -->
  <Target Name="IncrementBuildNumber" BeforeTargets="BeforeBuild">
    <ReadLinesFromFile File="$(BuildNumberFile)" Condition="Exists('$(BuildNumberFile)')">
      <Output TaskParameter="Lines" PropertyName="PreviousBuildNumber" />
    </ReadLinesFromFile>

    <PropertyGroup>
      <PreviousBuildNumber Condition="'$(PreviousBuildNumber)' == ''">0</PreviousBuildNumber>
      <BuildNumber>$([MSBuild]::Add($(PreviousBuildNumber), 1))</BuildNumber>
    </PropertyGroup>

    <WriteLinesToFile File="$(BuildNumberFile)" Lines="$(BuildNumber)" Overwrite="true" />
    <Message Importance="high" Text="Build number incremented to $(BuildNumber)." />
  </Target>

  <!--
    Applies the current (already-incremented) build number as the version. Runs in
    every build and pack pass so the compiled assembly and the generated NuGet
    package always share the same version. Read-only: it never mutates the counter.
  -->
  <Target Name="SetVersionFromBuildNumber" BeforeTargets="BeforeCompile;GenerateNuspec;Pack">
    <ReadLinesFromFile File="$(BuildNumberFile)" Condition="Exists('$(BuildNumberFile)')">
      <Output TaskParameter="Lines" PropertyName="CurrentBuildNumber" />
    </ReadLinesFromFile>

    <PropertyGroup>
      <CurrentBuildNumber Condition="'$(CurrentBuildNumber)' == ''">0</CurrentBuildNumber>
      <Version>1.0.$(CurrentBuildNumber)</Version>
      <PackageVersion>$(Version)</PackageVersion>
      <AssemblyVersion>$(Version).0</AssemblyVersion>
      <FileVersion>$(Version).0</FileVersion>
      <InformationalVersion>$(Version)</InformationalVersion>
    </PropertyGroup>
  </Target>

</Project>
