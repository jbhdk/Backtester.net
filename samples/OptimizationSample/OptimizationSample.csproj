<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>OptimizationSample</RootNamespace>
    <AssemblyName>OptimizationSample</AssemblyName>

    <!-- A sample, never a package: it is run by hand and is not part of the test suite. -->
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <PropertyGroup>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
  </PropertyGroup>

  <ItemGroup>
    <!-- The committed OHLCV files the sweep reads, so the sample needs no data provider or credential. -->
    <Content Include="..\data\*_1d.csv" Link="data\%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Backtester\Backtester.csproj" />
    <ProjectReference Include="..\..\Optimization\Backtester.Optimization.csproj" />
    <ProjectReference Include="..\..\Report\Report.csproj" />
    <ProjectReference Include="..\..\Report.Toolkit\Report.Toolkit.csproj" />
  </ItemGroup>

</Project>
